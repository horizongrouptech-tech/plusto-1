{
  "name": "AgentSupportTicket",
  "type": "object",
  "properties": {
    "customer_email": {
      "type": "string",
      "format": "email",
      "description": "אימייל הלקוח שממנו הגיעה הפנייה"
    },
    "manager_email": {
      "type": "string",
      "format": "email",
      "description": "אימייל מנהל הכספים שיצר את הפנייה דרך הסוכן"
    },
    "subject": {
      "type": "string",
      "description": "נושא הפנייה (לדוגמה: 'באג בדף התחזיות', 'בקשת פיצ׳ר חדש')"
    },
    "description": {
      "type": "string",
      "description": "תיאור מפורט של הבאג/פיצ׳ר"
    },
    "type": {
      "type": "string",
      "enum": [
        "bug_report",
        "feature_request"
      ],
      "description": "סוג הפנייה"
    },
    "status": {
      "type": "string",
      "enum": [
        "new",
        "in_review",
        "prioritized",
        "resolved",
        "rejected"
      ],
      "default": "new",
      "description": "סטטוס טיפול בפנייה"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "urgent"
      ],
      "default": "medium",
      "description": "רמת דחיפות"
    },
    "related_context": {
      "type": "string",
      "description": "הקשר נוסף מהשיחה עם הסוכן (לדוגמה: דף בו התרחש הבאג)"
    },
    "resolution_notes": {
      "type": "string",
      "description": "הערות צוות הניהול לגבי פתרון הפנייה"
    },
    "resolved_by": {
      "type": "string",
      "format": "email",
      "description": "אימייל האדמין/מפתח שפתר את הפנייה"
    },
    "resolved_date": {
      "type": "string",
      "format": "date-time",
      "description": "תאריך פתרון הפנייה"
    }
  },
  "required": [
    "manager_email",
    "subject",
    "description",
    "type"
  ],
  "rls": {
    "create": true,
    "read": true,
    "update": true,
    "delete": true
  }
}